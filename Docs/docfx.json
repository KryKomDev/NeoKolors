{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../Src",
          "files": [
            "Common/NeoKolors.Common.csproj",
            "Console/NeoKolors.Console.csproj",
            "Extensions/NeoKolors.Extensions.csproj",
            "Settings/NeoKolors.Settings.csproj",
            "Tui/NeoKolors.Tui.csproj",
            "Tui/Core/NeoKolors.Tui.Core.csproj",
            "Tui/Fonts/NeoKolors.Tui.Fonts.csproj",
            "Tui/Fonts/Assets/NeoKolors.Tui.Fonts.Assets.csproj"
          ]
        }
      ],
      "dest": "api",
      "filter": "filterConfig.yml",
      "memberLayout": "separatePages"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "index.md",
          "toc.yml",
          "articles/toc.yml"
        ]
      },
      {
        "files": [
          "api/**/*.yml",
          "api/toc.yml"
        ]
      },
      {
        "src": "../Src/Common/Docs",
        "files": ["**/*.md"],
        "dest": "articles/common"
      },
      {
        "src": "../Src/Console/Docs",
        "files": ["**/*.md"],
        "dest": "articles/console"
      },
      {
        "src": "../Src/Extensions/Docs",
        "files": ["**/*.md"],
        "dest": "articles/extensions"
      },
      {
        "src": "../Src/Settings/Docs",
        "files": ["**/*.md"],
        "dest": "articles/settings"
      },
      {
        "src": "../Src/Tui/Docs",
        "files": ["**/*.md"],
        "dest": "articles/tui"
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "assets/**"
        ]
      },
      {
        "files": [
          "Font.xsd",
          "Font.Common.xsd",
          "Font.Config.xsd",
          "Font.Manifest.xsd",
          "Font.Map.xsd"
        ],
        "src": "../Src/Tui/Schemas/Fonts/V3",
        "dest": "Schemas/Fonts/v3/"
      }
    ],
    "sitemap": {
      "baseUrl": "https://krykomdev.github.io/NeoKolors",
      "priority": 0.5,
      "changefreq": "monthly"
    },
    "output": "_site",
    "template": [
      "default",
      "modern",
      "templates/dokfx"
    ],
    "globalMetadata": {
      "_appName": "NeoKolors",
      "_appTitle": "NeoKolors Documentation",
      "_appLogoPath": "assets/package-icon.png",
      "_appFaviconPath": "assets/package-icon.png",
      "_enableSearch": true,
      "pdf": false,
      "_appFooter": "<span>Copyright &copy; 2026 KryKom · Licensed under the MIT License · Source code on <a href='https://github.com/KryKomDev/NeoKolors' target='_blank'>GitHub</a> · Generated by <a href='https://dotnet.github.io/docfx/' target='_blank'>DocFX</a> using the <a href='https://github.com/KryKomDev/Dokfx' target='_blank'>Dokfx template</a></span>"
    }
  }
}
